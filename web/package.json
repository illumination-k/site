{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "run-s build:next build:pagefind",
    "build:next": "next build",
    "build:pagefind": "pagefind --site out",
    "dev": "run-p dev:*",
    "dev-pagefind": "pagefind --site out --output-path ./public/pagefind",
    "dev:next": "rm -rf .next && next dev",
    "format": "prettier --write ./src ./*.ts ./*.mjs && eslint --fix ./src",
    "lint": "eslint ./src",
    "prepare": "panda codegen",
    "start": "next start",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@mdx-js/mdx": "^3.1.1",
    "@next/third-parties": "^16.2.0",
    "common": "workspace:^",
    "katex": "^0.16.39",
    "next": "16.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remeda": "^2.33.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@next/env": "^16.2.0",
    "@next/eslint-plugin-next": "16.2.0",
    "@pandacss/dev": "^1.9.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/gtag.js": "^0.0.20",
    "@types/jest": "^30.0.0",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "~9.39.4",
    "eslint-config-next": "16.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^29.0.1",
    "pagefind": "^1.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
