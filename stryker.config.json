{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-core.schema.json",
  "testRunner": "vitest",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "incremental": true,
  "incrementalFile": "reports/mutation/stryker-incremental.json",
  "reporters": ["clear-text", "html", "json", "progress"],
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "jsonReporter": {
    "fileName": "reports/mutation/mutation.json"
  },
  "mutate": [
    "packages/md-plugins/**/*.ts",
    "packages/ipynb2md/src/**/*.ts",
    "cli/**/*.ts",
    "web/src/features/articles/service.ts",
    "web/src/features/articles/utils/**/*.ts",
    "web/src/features/articles/repository/**/*.ts",
    "web/src/features/articles/components/Pager.tsx",
    "web/src/features/articles/components/PostCard.tsx",
    "web/src/features/articles/components/Tag.tsx",
    "web/src/features/articles/components/Post/Header.tsx",
    "web/src/features/articles/components/Post/Footer.tsx",
    "web/src/features/articles/components/Post/index.tsx",
    "web/src/app/_util/**/*.{ts,tsx}",
    "web/src/app/**/_factory/**/*.tsx",
    "web/src/lib/i18n/config.ts",
    "web/src/lib/i18n/getDictionary.ts",
    "!**/*.test.ts",
    "!**/*.test.tsx",
    "!**/*.spec.ts",
    "!**/*.spec.tsx",
    "!**/*.d.ts",
    "!**/vitest.config.ts",
    "!**/tsup.config.ts",
    "!**/dist/**",
    "!**/node_modules/**"
  ]
}
